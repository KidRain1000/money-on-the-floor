{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/games",
      "dest": "/api/games.js"
    },
    {
      "src": "/api/players",
      "dest": "/api/players.js"
    },
    {
      "src": "/api/injuries",
      "dest": "/api/injuries.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
